# =============================================================================
# Alertify Backend (.gitignore) - NestJS / Node / Docker / Environment
# =============================================================================

# CRITICAL: Never commit environment variables with secrets
# All .env files are ignored except .env.example (if you want to share template)
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
.env.*.production
.env.*.development

# Node.js Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
npm-shrinkwrap.json

# Build Outputs
dist/
build/
*.tsbuildinfo
.nest-cli.json.build

# Compiled JavaScript (keep .js files in .gitignore for TS projects)
*.js
*.js.map
!jest.config.js
!eslint.config.mjs
!nest-cli.json
!nestjs-cli-config.js

# Code Coverage & Testing
coverage/
.nyc_output/
junit.xml
test-results/
*.lcov

# Logs & Debugging
logs/
log/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
debug/
.debug/

# Operating System
.DS_Store
Thumbs.db
._*
.AppleDouble
.LSOverride

