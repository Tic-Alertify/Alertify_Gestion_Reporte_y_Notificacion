.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace
.netbeans/

# Database & Cache Files
*.db
*.sqlite
*.sqlite3
dump.rdb
.cache/
.eslintcache

# Temporary & Cache Directories
tmp/
temp/
.temp/
.tmp/
pids/
*.pid
*.seed
*.pid.lock

# Docker & Containerization
.dockerignore
docker-compose.override.yml

# Backup & Temporary Files
*.bak
*.backup
*~
*.swp
*.swo

