  "item": [
    {
      "name": "Setup - Datos de Prueba",
      "item": [
        {
          "name": "📊 Obtener Usuarios Existentes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var users = pm.response.json();",
                  "    if (users.length > 0) {",
                  "        pm.environment.set('userId', users[0].IdUsuario);",
                  "        pm.environment.set('userName', users[0].Nombre);",
                  "        console.log('✅ Usuario configurado:', users[0].Nombre);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "CP-01: Creación de Reporte Válido",
      "item": [
        {
          "name": "✅ Crear Reporte Dentro del DMO",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code es 201 Created', function () {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "",
                  "pm.test('Respuesta contiene idReporte', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.IdReporte).to.exist;",
                  "    pm.environment.set('reportId_CP01', jsonData.IdReporte);",
                  "});",
                  "",
                  "pm.test('Estado inicial es 0 (Pendiente)', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.Estado).to.equal(0);",
                  "});",
                  "",
                  "pm.test('Ubicación geográfica está correcta', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.UbicacionGeografica.latitude).to.equal(-0.2217);",
                  "    pm.expect(jsonData.UbicacionGeografica.longitude).to.equal(-78.4956);",
                  "});",
                  "",
                  "console.log('✅ CP-01 CUMPLE: Reporte creado exitosamente');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"userId\\\": 1,\\n  \\\"incidentTypeId\\\": 1,\\n  \\\"latitude\\\": -0.2217,\\n  \\\"longitude\\\": -78.4956,\\n  \\\"description\\\": \\\"Robo reportado cerca del parque central\\\"\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports",
              "host": ["{{baseUrl}}"],
              "path": ["reports"]
            }
          }
        }
      ]
    },
    {
      "name": "CP-02: Detección de Límites del DMO",
      "item": [
        {
          "name": "❌ Crear Reporte Fuera del DMO (Fallo Esperado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code es 400 BadRequest', function () {",
                  "    pm.expect(pm.response.code).to.equal(400);",
                  "});",
                  "",
                  "pm.test('Mensaje de error menciona zona de cobertura', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('zona de cobertura');",
                  "    pm.expect(jsonData.message).to.include('Quito');",
                  "});",
                  "",
                  "console.log('✅ CP-02 CUMPLE: Geofencing válida - rechaza ubicación fuera de Quito');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"userId\\\": 1,\\n  \\\"incidentTypeId\\\": 1,\\n  \\\"latitude\\\": 1.5,\\n  \\\"longitude\\\": -75.0,\\n  \\\"description\\\": \\\"Incidente fuera de cobertura\\\"\\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports",
              "host": ["{{baseUrl}}"],
              "path": ["reports"]
            }
          }
        }
      ]
    },
