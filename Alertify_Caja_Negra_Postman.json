        },
        {
          "name": "⏳ Esperar 3 segundos para procesamiento",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Wait 3 seconds for queue processing",
                  "pm.sendRequest({",
                  "    url: 'https://httpbin.org/delay/3',",
                  "    method: 'GET'",
                  "}, function (err, response) {",
                  "    if (!err) {",
                  "        console.log('✅ Tiempo de espera completado'):",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://httpbin.org/delay/3",
              "protocol": "https",
              "host": ["httpbin.org"],
              "path": ["delay", "3"]
            }
          }
        },
        {
          "name": "✅ Verificar Reporte Validado (Estado 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Endpoint retorna reportes validados', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Existe al menos un reporte validado', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Reporte validado tiene CS >= 0.60', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var report = jsonData.find(r => r.estado === 1);",
                  "    if (report) {",
                  "        pm.expect(report.trustScore).to.be.greaterThanOrEqual(0.60);",
                  "        console.log('✅ CP-04 CUMPLE: Reporte validado con CS =', report.trustScore);",
                  "    } else {",
                  "        console.log('⚠️  No hay reportes validados aún - puede reintentarse'):",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/validated",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "validated"]
            }
          }
        }
      ]
